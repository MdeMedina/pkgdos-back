generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String      @id @default(uuid()) @db.Uuid
  full_name           String
  email               String      @unique
  password_hash       String
  global_role         GlobalRole  @default(operator)
  session_token_n8n   String?
  friction_level      Float       @default(0.0)
  calcification_level Float       @default(0.0)
  department_id       String?     @db.Uuid
  department_role_id  String?     @db.Uuid
  created_at          DateTime    @default(now())
  updated_at          DateTime    @default(now()) @updatedAt
  sessions            Session[]
  brands              UserBrand[]
  diagnostics         UserDiagnostic[]
  department          Department? @relation(fields: [department_id], references: [id], onDelete: SetNull)
  department_role     DepartmentRole? @relation(fields: [department_role_id], references: [id], onDelete: SetNull)

  @@map("users")
}

model UserDiagnostic {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  source_session_id String?  @db.Uuid
  trigger_reason    String
  summary           String   @default("")
  payload           Json     @default("{}")
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  source_session    Session? @relation("DiagnosticSourceSession", fields: [source_session_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at(sort: Desc)])
  @@map("user_diagnostics")
}

model Brand {
  id               String           @id @default(uuid()) @db.Uuid
  name             String
  industry         String
  status           BrandStatus      @default(Active)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt
  knowledge_assets KnowledgeAsset[]
  sessions         Session[]
  users            UserBrand[]

  @@map("brands")
}

model UserBrand {
  user_id  String @db.Uuid
  brand_id String @db.Uuid
  brand    Brand  @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, brand_id])
  @@map("user_brands")
}

model Session {
  id                             String               @id @default(uuid()) @db.Uuid
  user_id                        String               @db.Uuid
  brand_id                       String?              @db.Uuid
  title                          String
  status                         SessionStatus        @default(Open)
  friction_level                 Float                @default(0.0)
  calcification_delta            Float                @default(0.0)
  interval_count                 Int                  @default(0)
  glitch_count                   Int                  @default(0)
  encauzamiento_count            Int                  @default(0)
  coupling_node_triggered        Boolean              @default(false)
  coupling_attempts              Int                  @default(0)
  coupling_active                Boolean              @default(false)
  resolution_status              ResolutionStatus     @default(Unresolved)
  integration_signal_received_at DateTime?
  gold_extraction_status         GoldExtractionStatus @default(None)
  transcript_payload             Json                 @default("[]")
  glitches                       Json                 @default("[]")
  extracted_asset_id             String?              @db.Uuid
  created_at                     DateTime             @default(now())
  updated_at                     DateTime             @default(now()) @updatedAt
  source_knowledge               KnowledgeAsset[]     @relation("KnowledgeSourceSession")
  diagnostics                    UserDiagnostic[]     @relation("DiagnosticSourceSession")
  brand                          Brand?               @relation(fields: [brand_id], references: [id])
  extracted_asset                KnowledgeAsset?      @relation("SessionExtractedAsset", fields: [extracted_asset_id], references: [id])
  user                           User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model KnowledgeAsset {
  id                   String              @id @default(uuid()) @db.Uuid
  brand_id             String?             @db.Uuid
  title                String
  asset_type           AssetType
  status               String              @default("Active")
  source_file_url      String?
  pgvector_ref_id      String?
  vectorization_status VectorizationStatus @default(Pending)
  percent              Float               @default(0.0)
  source_session_id    String?             @db.Uuid
  created_at           DateTime            @default(now())
 
  brand          Brand?           @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  source_session Session?         @relation("KnowledgeSourceSession", fields: [source_session_id], references: [id], onDelete: SetNull)
  chunks         DocumentChunk[]
  
  extracted_from_sessions Session[] @relation("SessionExtractedAsset")
  ingestion_jobs          IngestionJob[]
  department_id           String?             @db.Uuid
  department_role_id      String?             @db.Uuid
  department              Department?         @relation(fields: [department_id], references: [id], onDelete: SetNull)
  department_role         DepartmentRole?     @relation(fields: [department_role_id], references: [id], onDelete: SetNull)

  @@map("knowledge_assets")
}

model IngestionJob {
  id                 String   @id @default(uuid()) @db.Uuid
  knowledge_asset_id String   @db.Uuid
  status             String
  callback_url       String?
  source_file_url    String?
  processed_chunks   Int      @default(0)
  total_chunks       Int      @default(0)
  percent            Float    @default(0.0)
  error              String?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now()) @updatedAt

  knowledge_asset    KnowledgeAsset @relation(fields: [knowledge_asset_id], references: [id], onDelete: Cascade)

  @@map("ingestion_jobs")
}

model Department {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @unique
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt
  users            User[]
  roles            DepartmentRole[]
  knowledge_assets KnowledgeAsset[]

  @@map("departments")
}

model DepartmentRole {
  id               String           @id @default(uuid()) @db.Uuid
  name             String
  department_id    String           @db.Uuid
  department       Department       @relation(fields: [department_id], references: [id], onDelete: Cascade)
  users            User[]
  knowledge_assets KnowledgeAsset[]
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt

  @@unique([department_id, name])
  @@map("department_roles")
}

model DocumentChunk {
  id                 String         @id @default(uuid()) @db.Uuid
  knowledge_asset_id String         @db.Uuid
  content            String
  embedding          Unsupported("vector(1536)")?
  created_at         DateTime       @default(now())

  knowledge_asset KnowledgeAsset @relation(fields: [knowledge_asset_id], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

enum GlobalRole {
  admin
  operator
}

enum BrandStatus {
  Active
  Paused
  Archived
}

enum SessionStatus {
  Open
  Closed
  Archived
}

enum ResolutionStatus {
  Unresolved
  Resolved
  Stalled
}

enum GoldExtractionStatus {
  None
  Pending
  Extracted
  Failed
}

enum AssetType {
  SOP
  Dogma
  Gold
  Jewel
  External
}

enum VectorizationStatus {
  Pending
  Embedded
  Error
}
